#!/bin/bash
#SBATCH --partition=rome
#SBATCH --job-name=vllm-install
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --time=01:00:00
#SBATCH --output=vllm/logs/install_%j.out

set -e

mkdir -p vllm/logs

module purge
module load 2023
module load Anaconda3/2023.07-2
module load CUDA/12.1.1

source $(conda info --base)/etc/profile.d/conda.sh

if ! conda env list | grep -q "^vllm-env "; then
    conda create -y -n vllm-env python=3.11
fi

conda activate vllm-env

pip install vllm
