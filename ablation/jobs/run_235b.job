#!/bin/bash
#SBATCH --partition=gpu_h100
#SBATCH --gpus=4
#SBATCH --job-name=ablation-235b
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=320G
#SBATCH --time=12:00:00
#SBATCH --output=ablation/logs/run_235b_%j.out

# Qwen3-VL-235B-A22B-Instruct is a sparse MoE model.
# Full weights at bfloat16 ≈ 470 GB — exceeds 4 × H100 (320 GB).
# FP8 quantization halves weight memory to ~235 GB, leaving ~85 GB for KV
# cache across 4 H100s.  If the cluster supports 8 H100s per node, drop
# --quantization fp8 and use --gpus=8 --tensor-parallel-size 8 instead.

set -e
mkdir -p ablation/logs

module purge
module load 2023
module load Anaconda3/2023.07-2
module load CUDA/12.1.1

source $(conda info --base)/etc/profile.d/conda.sh
conda activate vllm-env

export HF_HOME=/scratch-shared/$USER/.cache/huggingface

MODEL_NAME="Qwen/Qwen3-VL-235B-A22B-Instruct"
MODEL_PARAMS=235
PORT=8267

echo "=== Starting vLLM for $MODEL_NAME (fp8) on port $PORT ==="
python -m vllm.entrypoints.openai.api_server \
    --model "$MODEL_NAME" \
    --port $PORT \
    --max-model-len 8192 \
    --tensor-parallel-size 4 \
    --quantization fp8 &
VLLM_PID=$!

echo "Waiting for vLLM to be ready (235B loads slowly — up to 15 min)..."
MAX_WAIT=1800
ELAPSED=0
until curl -sf "http://localhost:$PORT/health" > /dev/null 2>&1; do
    sleep 20; ELAPSED=$((ELAPSED + 20))
    if [ $ELAPSED -ge $MAX_WAIT ]; then
        echo "ERROR: vLLM did not start within ${MAX_WAIT}s"; kill $VLLM_PID; exit 1
    fi
done
echo "vLLM ready after ${ELAPSED}s"

echo "=== Running ablation ==="
python ablation/ablation.py \
    --model-name   "$MODEL_NAME" \
    --model-params $MODEL_PARAMS \
    --model-url    "http://localhost:$PORT/v1" \
    --n-questions  500 \
    --out          ablation/results.csv

echo "=== Stopping vLLM ==="
kill $VLLM_PID
wait $VLLM_PID 2>/dev/null || true
echo "Done."
