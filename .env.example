# ── offline image pipeline ──
MMPEDIA_AUTO_DOWNLOAD=1
MMPEDIA_KEEP_ARCHIVES=0
MMPEDIA_FETCH_ALL=0

# ── LLM via OpenRouter (OpenAI-compatible) ──
OPENROUTER_API_KEY=sk-o
# Route all three model slots through OpenRouter. Use provider-prefixed ids:
#   openai/gpt-4o · anthropic/claude-3.7-sonnet · meta-llama/llama-3.1-70b-instruct
ANSWER_MODEL=openai/gpt-4o
CLAIMS_MODEL=openai/gpt-4o
VERIFIER_MODEL=openai/gpt-4o
# VERIFIER=llm   # "llm" (default, uses VERIFIER_MODEL) or "nli" (local model, no API)
